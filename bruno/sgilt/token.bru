meta {
  name: token
  type: http
  seq: 2
}

post {
  url: http://localhost:5028/realms/sgilt/protocol/openid-connect/token
  body: formUrlEncoded
  auth: inherit
}

body:form-urlencoded {
  client_id: sgilt-front
  username: fk@ka.sgilt
  password: aa
  grant_type: password
}

script:post-response {
  const token = res.body.access_token;
  bru.setEnvVar('login_token', token);
}
