# ======================
# Environment
# ======================
ENV=staging

# ======================
# Image versions
# ======================
SGILT_FRONT_VERSION=1.0.0
SGILT_KEYCLOAK_VERSION=1.0.0
SGILT_SMTP_BRIDGE_VERSION=1.0.0
SGILT_MAILER_VERSION=1.0.0

# ======================
# URLs
# ======================
APP_URL=https://staging.sgilt.fr
AUTH_URL=https://auth-staging.sgilt.fr
NUXT_PUBLIC_SITE_URL=https://staging.sgilt.fr

# ======================
# Nuxt
# ======================
NUXT_PUBLIC_SITE_URL=https://staging.sgilt.fr

# ======================
# Keycloak
# ======================
KEYCLOAK_ISSUER=https://auth-staging.sgilt.fr/realms/sgilt

# ======================
# Nginx
# ======================
APP_DOMAIN=staging.sgilt.fr
AUTH_DOMAIN=auth-staging.sgilt.fr
API_DOMAIN=api-staging.sgilt.fr

NGINX_FRONT_PORT=6700
NGINX_AUTH_PORT=6701
NGINX_API_PORT=6702
