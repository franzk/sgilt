# ======================
# Environment
# ======================
ENV=production

# ======================
# Image versions
# ======================
SGILT_FRONT_VERSION=1.0.0
SGILT_KEYCLOAK_VERSION=1.0.0
SGILT_SMTP_BRIDGE_VERSION=1.0.0
SGILT_MAILER_VERSION=1.0.0

# ======================
# URLs
# ======================
APP_URL=https://sgilt.alsace
AUTH_URL=https://auth.sgilt.alsace
API_URL=https://api.sgilt.alsace

# ======================
# Nuxt
# ======================
NUXT_PUBLIC_SITE_URL=https://sgilt.alsace

# ======================
# Keycloak
# ======================
KEYCLOAK_ISSUER=https://auth.sgilt.alsace/realms/sgilt

# ======================
# Nginx
# ======================
APP_DOMAIN=sgilt.alsace
AUTH_DOMAIN=auth.sgilt.alsace
API_DOMAIN=api.sgilt.alsace

NGINX_FRONT_PORT=6710
NGINX_AUTH_PORT=6711
NGINX_API_PORT=6712
